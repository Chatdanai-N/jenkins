pipeline {
    agent any
    
    tools {
        // ต้องมั่นใจว่าใน Jenkins Global Tool Configuration ตั้งชื่อว่า 'maven3' ตรงกัน
        maven 'maven3'
    }

    parameters {
        string(name: 'GIT_TAG', defaultValue: 'main', description: 'ระบุชื่อ Tag หรือ Branch')
    }

    environment {
        IMAGE_NAME = "manga_app"
        IMAGE_TAG = "${params.GIT_TAG}-${env.BUILD_ID}"
        DOCKER_CONTAINER_NAME = "manga-app-container"
        // กำหนดโฟลเดอร์งานเพื่อความแม่นยำ
        APP_DIR = "manga_app" 
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    // ปรับ Checkout ให้รองรับทั้ง Branch และ Tag ได้ยืดหยุ่นขึ้น
                    checkout([$class: 'GitSCM', 
                        branches: [[name: "${params.GIT_TAG}"]], 
                        userRemoteConfigs: [[
                            url: 'https://github.com/Chatdanai-N/manga_app.git',
                            credentialsId: 'github-Chatdanai-N'
                        ]]
                    ])
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir("${env.APP_DIR}") {
                    // ใช้ mvn จาก tools ที่ประกาศไว้
                    sh 'mvn clean package -DskipTests=false'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                // ย้ายออกมาที่ Root (ที่ที่มี Dockerfile) 
                // หรือระบุ Path ของ Dockerfile ให้ถูกต้อง
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -f ${env.APP_DIR}/Dockerfile ${env.APP_DIR}"
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
            }
        }

        stage('Deploy') {
            steps {
                script {
                    // ป้องกัน Error กรณีไม่มี Container อยู่ก่อน
                    sh "docker stop ${DOCKER_CONTAINER_NAME} || true"
                    sh "docker rm ${DOCKER_CONTAINER_NAME} || true"
                    sh """
                        docker run -d \
                        --name ${DOCKER_CONTAINER_NAME} \
                        --network dev-network \
                        -p 8081:8080 \
                        ${IMAGE_NAME}:latest
                    """
                }
            }
        }
    }
    
    post {
        always {
            // เคลียร์ไฟล์หลังจบงานเพื่อประหยัดพื้นที่ Disk บน Jenkins
            cleanWs()
        }
    }
}