pipeline {
    agent any
    
    // เพิ่มส่วนนี้เพื่อให้ Jenkins ไปดึง Java 21 มาใช้รันสเตจต่างๆ
    tools {
        jdk 'jdk21' 
    }

    parameters {
        // แนะนำให้ใส่คำอธิบายชัดเจนว่าถ้าเป็น Tag ให้ใส่ชื่อ Tag เลย
        string(name: 'GIT_TAG', defaultValue: 'main', description: 'ระบุชื่อ Tag (เช่น v1.0.0) หรือ Branch (เช่น main)')
    }

    environment {
        IMAGE_NAME = "manga_app"
        IMAGE_TAG = "${params.GIT_TAG}-${env.BUILD_ID}"
        DOCKER_CONTAINER_NAME = "manga-app-container"
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'java -version'
                sh 'ls -l' // ดูว่าเห็นไฟล์ mvnw ในโฟลเดอร์ไหม
            }
        }

        stage('Checkout') {
            steps {
                script {
                    // ใช้ checkout scm เพื่อให้รองรับทั้ง Branch และ Tag อย่างละเอียด
                    checkout([$class: 'GitSCM', 
                        branches: [[name: "refs/tags/${params.GIT_TAG}"]], 
                        userRemoteConfigs: [[
                            url: 'https://github.com/Chatdanai-N/manga_app.git',
                            credentialsId: 'github-Chatdanai-N' // ใช้ ID ที่คุณตั้งไว้ใน Jenkins Credentials
                        ]],
                        doGenerateSubmoduleConfigurations: false,
                        extensions: [],
                        submoduleCfg: []
                    ])
                }
            }
        }

        stage('Build & Test') {
            steps {
                // เพิ่มการรัน Unit Test และ Scan ตามที่คุณเน้นเรื่อง Code Quality
                // ให้สิทธิ์การรันกับไฟล์ mvnw ก่อน
                sh 'chmod +x mvnw'
                sh './mvnw clean package -DskipTests=false'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
            }
        }

        stage('Deploy') {
            steps {
                script {
                    sh "docker stop ${DOCKER_CONTAINER_NAME} || true"
                    sh "docker rm ${DOCKER_CONTAINER_NAME} || true"
                    sh """
                        docker run -d \
                        --name ${DOCKER_CONTAINER_NAME} \
                        --network dev-network \
                        -p 8081:8080 \
                        ${IMAGE_NAME}:latest
                    """
                }
            }
        }
    }
}